{
  "$schema": "./node_modules/@biomejs/biome/configuration_schema.json",
  "vcs": {
    "enabled": false,
    "clientKind": "git",
    "useIgnoreFile": false
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 120
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": {
        "useKeyWithClickEvents": "off",
        "noStaticElementInteractions": "off",
        "useButtonType": "off",
        "useSemanticElements": "off",
        "noSvgWithoutTitle": "off",
        "useIframeTitle": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [{ "group": ["../../**", "@/../../**"] }, { "group": ["@/editor/**", "!@/editor"] }]
          }
        }
      },
      "security": {
        "noDangerouslySetInnerHtml": "off"
      },
      "suspicious": {
        "noExplicitAny": "off",
        "noArrayIndexKey": "off",
        "noTemplateCurlyInString": "off",
        "noNonNullAssertedOptionalChain": "off"
      },
      "correctness": {
        "useExhaustiveDependencies": "off",
        "noUnusedVariables": "error"
      },
      "nursery": {
        "useSortedClasses": "warn"
      },
      "complexity": {
        "noImportantStyles": "off"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single"
    }
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "src/**",
      "wasm/src/serde/values/**",
      "packages/**",
      "tests/**",
      "scripts/*",
      "vite.config.ts",
      "postcss.config.cjs",
      "tsconfig.json",
      ".vscode/settings.json",
      "!src/data/symbols.json",
      "!docs/Typst-Mate-Actions/tmactions.js",
      "!**/dist/*"
    ]
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": {
          "level": "on",
          "options": {
            "groups": ["@resources/**", "@ui/components/**", "@settings/**", "@typstmate/**", "@main.ts"]
          }
        }
      }
    }
  }
}
