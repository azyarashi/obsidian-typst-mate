{
  "name": "@typstmate/typst-syntax",
  "version": "0.14.2-1",
  "description": "Typst syntax definitions and parser",
  "keywords": [
    "typst",
    "typst-syntax",
    "parser",
    "syntax-highlighting",
    "codemirror",
    "codemirror-6",
    "typescript"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE"
  ],
  "scripts": {
    "build": "bun tsup src/typst-syntax/index.ts --format cjs,esm --dts --clean",
    "prepublishOnly": "bun run build",
    "publish": "npm publish --access public --tag latest",
    "typecheck": "bun tsc --noEmit",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "devDependencies": {
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
